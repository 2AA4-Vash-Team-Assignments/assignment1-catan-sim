%% ============================================================
%% Assignment 2 – Extended Domain Model
%% Human gameplay, visualization, robber, trading, step-forward
%% ============================================================
%% Changes from A1:
%% - Player hierarchy: AgentPlayer vs HumanPlayer (SRP, OCP)
%% - CommandParser for human input (regex); HumanInputReader
%% - GameStateSnapshot + GameStateWriter for JSON (R2.3, R2.2)
%% - Robber on Board; TurnPhase for step-forward (R2.4)
%% - Trading: BankTrade, DomesticTrade
%% ============================================================

classDiagram
    direction TB

    %% ==================== ENUMERATIONS ====================

    class ResourceType {
        <<enumeration>>
        WOOD
        BRICK
        WHEAT
        ORE
        SHEEP
    }

    class BuildingType {
        <<enumeration>>
        SETTLEMENT
        CITY
    }

    class TurnPhase {
        <<enumeration>>
        AWAIT_ROLL
        POST_ROLL
        ROBBER_DISCARD
        ROBBER_PLACE
        ROBBER_STEAL
        BUILD_OR_TRADE
        AWAIT_GO
    }

    %% ==================== GAME MANAGEMENT ====================

    class CatanGame {
        -currentRound : int
        -longestRoadLength : int
        -currentTurnPhase : TurnPhase
        -currentPlayerIndex : int
        -diceRollThisTurn : int
        +play() void
        +setupPhase() void
        +executeRound() boolean
        +executeTurn(player : Player) void
        +distributeResources(diceRoll : int) void
        +handleRollSeven() void
        +checkWinCondition() boolean
        +updateLongestRoad() void
        +printRoundSummary() void
        +waitForGo() void
        +writeGameState(path : String) void
    }

    class Configuration {
        -maxRounds : int
        -humanPlayerId : int
        +getMaxRounds() int
        +getHumanPlayerId() int
        +load(filePath : String) void
    }

    class Dice {
        +roll() int
    }

    class Bank {
        -supply : Map~ResourceType, Integer~
        +hasEnoughResources(type : ResourceType, amount : int) boolean
        +distributeResource(type : ResourceType, amount : int) void
        +collectResource(type : ResourceType, amount : int) void
        +getRemainingCount(type : ResourceType) int
    }

    class Demonstrator {
        +main(args : String[])$ void
    }

    %% ==================== BOARD & ROBBER ====================

    class Board {
        +initialize() void
        +getTilesForNumber(number : int) List~Tile~
        +getAvailableSettlementNodes(player : Player) List~Node~
        +getAvailableRoadEdges(player : Player) List~Edge~
        +getUpgradeableNodes(player : Player) List~Node~
        +getAvailableSetupNodes() List~Node~
        +calculateLongestRoad(player : Player) int
        +getTiles() List~Tile~
        +getNodes() List~Node~
        +getEdges() List~Edge~
    }

    class Robber {
        -currentTile : Tile
        +getCurrentTile() Tile
        +placeOn(tile : Tile) void
        +getTile() Tile
    }

    class Tile {
        -id : int
        -numberToken : int
        -resourceType : ResourceType
        +getId() int
        +getNumberToken() int
        +getResourceType() ResourceType
        +getAdjacentNodes() List~Node~
    }

    class Node {
        -id : int
        +getId() int
        +isOccupied() boolean
        +getBuilding() Building
        +satisfiesDistanceRule() boolean
        +getAdjacentNodes() List~Node~
        +getAdjacentTiles() List~Tile~
        +getAdjacentEdges() List~Edge~
    }

    class Edge {
        +isOccupied() boolean
        +getRoad() Road
        +getEndpoints() List~Node~
    }

    %% ==================== GAME PIECES ====================

    class Building {
        -type : BuildingType
        +getType() BuildingType
        +getOwner() Player
        +getVictoryPoints() int
        +getResourceMultiplier() int
    }

    class Road {
        +getOwner() Player
        +getEdge() Edge
    }

    %% ==================== PLAYER HIERARCHY (A2) ====================
    %% Abstract player; Agent and Human variants (OCP, SRP)

    class Player {
        <<abstract>>
        #id : int
        #resources : Map~ResourceType, Integer~
        #remainingSettlements : int
        #remainingCities : int
        #remainingRoads : int
        +getId() int
        +getVictoryPoints() int
        +getTotalResourceCards() int
        +getResourceCount(type : ResourceType) int
        +addResource(type : ResourceType, amount : int) void
        +removeResource(type : ResourceType, amount : int) void
        +canBuildRoad() boolean
        +canBuildSettlement() boolean
        +canBuildCity() boolean
        +buildRoad(edge : Edge) void
        +buildSettlement(node : Node) void
        +buildCity(node : Node) void
        +takeTurn(game : CatanGame, board : Board, bank : Bank) void
    }

    class AgentPlayer {
        -random : Random
        +takeTurn(game : CatanGame, board : Board, bank : Bank) void
        -chooseRandomAction(board : Board, bank : Bank, round : int) void
    }

    class HumanPlayer {
        -inputReader : HumanInputReader
        -commandParser : CommandParser
        +takeTurn(game : CatanGame, board : Board, bank : Bank) void
        +readCommand() ParsedCommand
    }

    %% ==================== HUMAN INPUT (R2.1) ====================

    class HumanInputReader {
        <<interface>>
        +readLine() String
        +hasNextLine() boolean
    }

    class ConsoleInputReader {
        -scanner : Scanner
        +readLine() String
        +hasNextLine() boolean
    }

    class CommandParser {
        -rollPattern : Pattern
        -goPattern : Pattern
        -listPattern : Pattern
        -buildSettlementPattern : Pattern
        -buildCityPattern : Pattern
        -buildRoadPattern : Pattern
        +parse(input : String) ParsedCommand
        +isRoll(cmd : ParsedCommand) boolean
        +isGo(cmd : ParsedCommand) boolean
    }

    class CommandType {
        <<enumeration>>
        ROLL
        GO
        LIST
        BUILD_SETTLEMENT
        BUILD_CITY
        BUILD_ROAD
        UNKNOWN
    }

    class ParsedCommand {
        -commandType : CommandType
        -nodeId : int
        -fromNodeId : int
        -toNodeId : int
        +getCommandType() CommandType
        +getNodeId() int
        +getFromNodeId() int
        +getToNodeId() int
    }

    %% ==================== GAME STATE EXPORT (R2.3, R2.2) ====================

    class GameStateSnapshot {
        -roads : List~RoadDTO~
        -buildings : List~BuildingDTO~
        -robberTileId : int
        -currentRound : int
        -currentPlayerId : int
        +getRoads() List
        +getBuildings() List
        +toJson() String
    }

    class GameStateWriter {
        -snapshotFactory : GameStateSnapshotFactory
        +writeState(game : CatanGame, filePath : String) void
    }

    class GameStateSnapshotFactory {
        +createFrom(game : CatanGame) GameStateSnapshot
    }

    %% ==================== TRADING ====================

    class TradeOffer {
        <<interface>>
        +canExecute(bank : Bank, player : Player) boolean
        +execute(bank : Bank, player : Player) void
    }

    class BankTrade {
        -give : Map~ResourceType, int~
        -receive : ResourceType
        +canExecute(bank : Bank, player : Player) boolean
        +execute(bank : Bank, player : Player) void
    }

    %% ==================== COMPOSITION ====================

    CatanGame "1" *-- "1" Board : contains
    CatanGame "1" *-- "4" Player : contains
    CatanGame "1" *-- "1" Dice : contains
    CatanGame "1" *-- "1" Bank : contains
    CatanGame "1" *-- "1" Configuration : contains
    CatanGame "1" *-- "1" Robber : contains
    CatanGame "1" *-- "1" GameStateWriter : uses

    Board "1" *-- "19" Tile : contains
    Board "1" *-- "54" Node : contains
    Board "1" *-- "72" Edge : contains

    Robber "1" --> "0..1" Tile : on

    %% ==================== ASSOCIATIONS ====================

    CatanGame "1" --> "0..1" Player : longestRoadHolder

    Tile "1..3" -- "6" Node : adjacentTo
    Node "2" -- "2..3" Edge : connectsTo
    Node "1" -- "0..1" Building : has
    Edge "1" -- "0..1" Road : has
    Building "*" --> "1" Player : ownedBy
    Road "*" --> "1" Player : ownedBy

    HumanPlayer "1" *-- "1" HumanInputReader : uses
    HumanPlayer "1" *-- "1" CommandParser : uses
    CommandParser ..> ParsedCommand : produces
    ParsedCommand --> CommandType : uses
    GameStateWriter "1" *-- "1" GameStateSnapshotFactory : uses
    GameStateSnapshotFactory ..> GameStateSnapshot : creates

    %% ==================== INHERITANCE ====================

    Player <|-- AgentPlayer
    Player <|-- HumanPlayer
    HumanInputReader <|.. ConsoleInputReader
    TradeOffer <|.. BankTrade

    %% ==================== DEPENDENCY ====================

    Demonstrator ..> CatanGame : creates

    note for Node "Self-association: adjacent to 2..3 other Nodes"
    note for CommandParser "R2.1: Parsing via regular expressions"
    note for GameStateWriter "R2.3: Writes state.json for visualizer (R2.2)"
    note for CatanGame "R2.4: waitForGo() blocks until 'go' command"
    note for Robber "R2.5: Place on random tile; steal from qualifying player"
